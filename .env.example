# ─────────────────────────────────────────────────────────────────────────────
# TuitionTruth 2.0 — environment template
# Copy to `.env` and fill in real values. NEVER commit `.env` (TUIT-1).
# Every variable here is validated at boot by a Zod schema; missing/invalid
# values fail the build fast rather than at runtime.
# ─────────────────────────────────────────────────────────────────────────────

# --- Database (packages/db) --------------------------------------------------
# Local dev via docker-compose defaults to this connection string.
DATABASE_URL="postgresql://tuitiontruth:tuitiontruth@localhost:5432/tuitiontruth"
# Max connections in the postgres-js pool.
DATABASE_POOL_MAX="10"

# --- Cache (Redis / Upstash) -------------------------------------------------
REDIS_URL="redis://localhost:6379"

# --- External data sources (apps/pipeline) -----------------------------------
# College Scorecard API key — https://api.data.gov/signup/
COLLEGE_SCORECARD_API_KEY=""

# --- Web app (apps/web) ------------------------------------------------------
# Public base URL, used for canonical links and OpenGraph metadata.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
