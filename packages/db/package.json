{
  "name": "@tuitiontruth/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "rollback": "tsx src/rollback.ts",
    "seed": "tsx src/seed.ts",
    "check": "drizzle-kit check",
    "studio": "drizzle-kit studio",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rm -rf .turbo coverage node_modules/.cache"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.11.1",
    "drizzle-orm": "^0.38.2",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tuitiontruth/config": "workspace:*",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
